NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://noirsound_user:noirsound_password@localhost:5432/noirsound_db?schema=public
DATABASE_URL_TEST=postgresql://noirsound_user:noirsound_password@localhost:5432/noirsound_test_db?schema=public
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Secrets: in PRODUCTION these must be >= 32 random chars and different from
# each other, or the server refuses to start. Generate with: openssl rand -hex 32
JWT_SECRET=dev_change_me_long_random_string
COOKIE_SECRET=dev_change_me_cookie_secret

# Comma-separated allowlist of browser origins (CORS + CSRF). Required in prod.
FRONTEND_ORIGIN=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

S3_ENDPOINT=http://localhost:9000
# Public/browser endpoint for signed URLs. In local dev this is the storage proxy.
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=noirsound-audio
S3_ACCESS_KEY_ID=noirsound_minio_user
S3_SECRET_ACCESS_KEY=noirsound_minio_password
S3_FORCE_PATH_STYLE=true
S3_IS_PUBLIC=false

# Public contact inboxes used by deployment/runbooks. Keep placeholders in dev.
SUPPORT_EMAIL=support@example.com
COPYRIGHT_EMAIL=copyright@example.com
ABUSE_EMAIL=abuse@example.com

# --- Ops / worker (optional) ---
TRUST_PROXY=false
LOG_LEVEL=info
AUDIO_WORKER_CONCURRENCY=2
FFPROBE_TIMEOUT_MS=30000
FFMPEG_TIMEOUT_MS=300000
MAX_AUDIO_DURATION_SECONDS=1800
# SENTRY_DSN=    # optional error monitoring hook
