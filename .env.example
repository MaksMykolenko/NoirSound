# NoirSound frontend environment template for local development.
# Production frontend builds use same-origin /api through Caddy.

# Real API mode (requires backend to be running)
VITE_USE_MOCK_API=false
VITE_API_BASE_URL=http://localhost:3000/api

# Mock API mode (runs frontend purely with mock data, no backend required)
# VITE_USE_MOCK_API=true
