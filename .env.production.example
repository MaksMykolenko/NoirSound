# NoirSound production environment — copy to .env.production and fill in.
# Generate strong secrets, e.g.:  openssl rand -hex 32
# The backend REFUSES TO START in production with weak/missing secrets.

DOMAIN=noirsound.app
FRONTEND_ORIGIN=https://noirsound.app

# --- Secrets (min 32 random chars; JWT_SECRET != COOKIE_SECRET) ---
JWT_SECRET=__CHANGE_ME_64_HEX__
COOKIE_SECRET=__CHANGE_ME_DIFFERENT_64_HEX__

# --- PostgreSQL ---
POSTGRES_USER=noirsound
POSTGRES_PASSWORD=__CHANGE_ME_STRONG__
POSTGRES_DB=noirsound
DATABASE_URL=postgresql://noirsound:__CHANGE_ME_STRONG__@postgres:5432/noirsound

# --- Redis (queue + rate limiting) ---
REDIS_URL=redis://redis:6379

# --- Object storage (MinIO/S3) ---
S3_ENDPOINT=http://minio:9000
# Browser-reachable endpoint used only when signing PUT/GET URLs. Caddy proxies
# /<bucket>/* to the private MinIO service, so this remains same-origin.
S3_PUBLIC_ENDPOINT=https://noirsound.app
S3_REGION=us-east-1
S3_BUCKET=noirsound-audio
S3_ACCESS_KEY_ID=__CHANGE_ME__
S3_SECRET_ACCESS_KEY=__CHANGE_ME_STRONG__
S3_FORCE_PATH_STYLE=true
S3_IS_PUBLIC=false

# --- Worker / media limits (optional overrides) ---
AUDIO_WORKER_CONCURRENCY=2
FFPROBE_TIMEOUT_MS=30000
FFMPEG_TIMEOUT_MS=300000
MAX_AUDIO_DURATION_SECONDS=1800

# --- Ops ---
TRUST_PROXY=true
LOG_LEVEL=info
# SENTRY_DSN=    # optional error monitoring hook
