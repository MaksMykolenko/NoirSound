# NoirSound production environment template.
# Copy this file to .env.production on the VPS only. Do not commit .env.production.
# Generate secrets with: openssl rand -hex 32
# The backend refuses to start in production while CHANGE_ME/example.com placeholders remain.

NODE_ENV=production
PORT=3000

# --- Public domain / browser URLs ---
# DOMAIN is the canonical host Caddy serves and provisions TLS for.
DOMAIN=example.com
PUBLIC_APP_URL=https://example.com
PUBLIC_API_URL=https://example.com/api

# CSRF + CORS allowlist.
# CRITICAL: FRONTEND_ORIGIN must list the EXACT origin(s) the browser shows in
# the address bar — scheme + host (+ port if non-standard), NO trailing slash.
# The backend reads FRONTEND_ORIGIN for BOTH the CORS and the CSRF allowlists.
#
# A mismatch here is the #1 cause of CSRF_VALIDATION_FAILED on Save:
#   - users open https://www.example.com but only https://example.com is listed
#   - the value still says https://example.com on a site served from a new domain
#   - http:// vs https:// scheme mismatch
# If apex AND www are both reachable, list both (comma-separated, no spaces
# required but trimmed). Prefer also redirecting www -> apex in the Caddyfile so
# there is a single canonical origin.
FRONTEND_ORIGIN=https://example.com,https://www.example.com
# Informational mirror of the above; the app derives CORS from FRONTEND_ORIGIN.
CORS_ORIGINS=https://example.com,https://www.example.com
# Cookie hardening — keep these as-is in production (do NOT weaken).
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax

# --- Google OAuth (Web application client) ---
# Add this exact redirect URI in Google Auth Platform as an authorized redirect URI.
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_REDIRECT_URI=https://example.com/api/auth/google/callback

# --- PostgreSQL ---
POSTGRES_DB=noirsound
POSTGRES_USER=noirsound
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM
DATABASE_URL=postgresql://noirsound:CHANGE_ME_LONG_RANDOM@postgres:5432/noirsound

# --- Redis (queue + rate limiting) ---
REDIS_URL=redis://redis:6379

# --- Private MinIO / S3-compatible storage ---
# The Compose stack uses the S3 access key pair below as MinIO root credentials.
S3_ENDPOINT=http://minio:9000
# Browser-reachable signed URL endpoint. Caddy proxies /<bucket>/* to private MinIO.
S3_PUBLIC_ENDPOINT=https://example.com
S3_REGION=us-east-1
S3_BUCKET=noirsound-audio
S3_ACCESS_KEY_ID=CHANGE_ME
S3_SECRET_ACCESS_KEY=CHANGE_ME_LONG_RANDOM
S3_FORCE_PATH_STYLE=true
S3_IS_PUBLIC=false

# --- App secrets (must be different, long, random values) ---
# Sessions are server-side records bound to JWT_SECRET; signed cookies use COOKIE_SECRET.
JWT_SECRET=CHANGE_ME_LONG_RANDOM
COOKIE_SECRET=CHANGE_ME_LONG_RANDOM
# CSRF protection uses the strict FRONTEND_ORIGIN allowlist instead of a separate token secret.

# --- Public contact inboxes ---
SUPPORT_EMAIL=support@example.com
COPYRIGHT_EMAIL=copyright@example.com
ABUSE_EMAIL=abuse@example.com

# --- Worker / media limits ---
AUDIO_WORKER_CONCURRENCY=2
FFPROBE_TIMEOUT_MS=30000
FFMPEG_TIMEOUT_MS=300000
MAX_AUDIO_DURATION_SECONDS=1800

# --- Ops ---
TRUST_PROXY=true
LOG_LEVEL=info
# SENTRY_DSN=    # optional error monitoring hook
